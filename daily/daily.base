filters:
  and:
    - file.folder == "daily"
    - file.ext == "md"
views:
  - type: table
    name: daily表格
    filters:
      and:
        - file.inFolder("daily")
        - file.ext == "md"
    order:
      - file.name
      - weekday
      - weather
      - mood
      - important
    sort:
      - property: file.basename
        direction: ASC
      - property: date
        direction: DESC
  - type: cards
    name: daily卡片
    cardSize: 140
    imageAspectRatio: 1
